{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://gestao.colaboraedu.cloud/api/v1",
        "EXPO_PUBLIC_TENANT_SLUG": "colegio-frei-ronaldo"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://gestao.colaboraedu.cloud/api/v1",
        "EXPO_PUBLIC_TENANT_SLUG": "colegio-frei-ronaldo"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
