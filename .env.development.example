# =============================================================================
# ColaboraEdu — Template de ambiente para desenvolvimento LOCAL (sem Docker)
# Copie este arquivo e preencha com suas credenciais locais:
#   cp .env.development.example .env.development
#
# O arquivo .env.development é gitignored — nunca commite credenciais reais.
#
# Requerimentos externos (podem rodar via Docker apenas de infra):
#   docker compose up postgres redis   ← sobe só banco + cache
# =============================================================================

# ── Ambiente ──────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── Banco de dados ────────────────────────────────────────────────────────────
# Postgres local (porta 5440 exposta pelo docker-compose.yml)
DATABASE_URL=postgresql://postgres:password@localhost:5440/colabora_edu

# Alternativa: SQLite (zero config, sem Docker)
# DATABASE_URL=sqlite:///data/boletins.db

# ── Cache / Filas ─────────────────────────────────────────────────────────────
# Redis local (porta 6389 exposta pelo docker-compose.yml)
REDIS_URL=redis://localhost:6389/0

# ── Flask ─────────────────────────────────────────────────────────────────────
# Chaves dev — NÃO use em produção
SECRET_KEY=dev-secret-key-only-for-local-development
JWT_SECRET_KEY=dev-jwt-key-only-for-local-development

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
FRONTEND_URL=http://localhost:5173
BRAND_NAME=ColaboraEdu (Dev)

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=../data/uploads

# ── SMTP (desativado em dev — e-mails só aparecem no log) ────────────────────
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost

# ── WhatsApp (desativado em dev) ──────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
