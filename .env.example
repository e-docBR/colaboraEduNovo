# =============================================================================
# ColaboraEdu — Variáveis de Ambiente de Produção
# =============================================================================
# 1. Copie este arquivo:  cp .env.example .env
# 2. Preencha TODOS os campos marcados com TROQUE_...
# 3. NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# INFRA — Domínio e TLS (Traefik / Let's Encrypt)
# -----------------------------------------------------------------------------

# Domínio público da aplicação (sem https://)
# Exemplo: app.minhaescola.com.br
DOMAIN=app.minhaescola.com.br

# E-mail para geração automática do certificado SSL (Let's Encrypt)
ACME_EMAIL=admin@minhaescola.com.br

# -----------------------------------------------------------------------------
# MONITORAMENTO — Uptime Kuma
# -----------------------------------------------------------------------------
# O painel de monitoramento fica em https://monitor.<DOMAIN>
# Protegido por senha via Traefik Basic Auth.
#
# Como gerar (execute no servidor):
#   apt install apache2-utils -y   # ou: brew install httpd
#   htpasswd -nb admin SUASENHA | sed 's/\$/\$\$/g'
#
# Exemplo de saída (use o valor completo):
#   admin:$$apr1$$xyz$$AbCdEfGhIjKlMnOpQrStU/
#
MONITOR_BASICAUTH=admin:$$apr1$$TROQUE_POR_HASH_GERADO_COM_HTPASSWD

# -----------------------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_USER=colabora_user
# Gere com: openssl rand -hex 24
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=colabora_edu

# Usuário limitado (apenas DML) para o Flask em runtime — mais seguro que usar o superusuário
# Criado automaticamente pelo scripts/init_app_user.sh no primeiro start do container Postgres
APP_DB_USER=colabora_app
# Gere com: openssl rand -hex 24
APP_DB_PASSWORD=TROQUE_POR_SENHA_FORTE

# -----------------------------------------------------------------------------
# CACHE / FILAS — Redis
# -----------------------------------------------------------------------------

# Gere com: openssl rand -hex 24
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS

# -----------------------------------------------------------------------------
# FLASK / BACKEND
# -----------------------------------------------------------------------------

FLASK_ENV=production

# Chaves secretas — DEVEM ser diferentes entre si, mínimo 32 chars.
# Gere com: openssl rand -hex 32
SECRET_KEY=TROQUE_POR_CHAVE_SECRETA_32_CHARS_MINIMO
JWT_SECRET_KEY=TROQUE_POR_JWT_SECRET_32_CHARS_MINIMO

# Chave dedicada para criptografia de segredos no banco (API keys de IA, tokens).
# DEVE ser diferente de SECRET_KEY e JWT_SECRET_KEY — assim é possível rotacionar
# SECRET_KEY (sessões/CSRF) sem invalidar os segredos armazenados.
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=TROQUE_POR_ENCRYPTION_KEY_32_CHARS_MINIMO

# URL pública do frontend (usada nos links do e-mail de recuperação de senha)
FRONTEND_URL=https://app.minhaescola.com.br

# Origens permitidas no CORS (JSON array de strings)
ALLOWED_ORIGINS=["https://app.minhaescola.com.br"]

# Nome exibido nos e-mails e na interface
BRAND_NAME=ColaboraEdu

# Pasta de uploads dentro do container (não altere sem mudar o volume)
UPLOAD_FOLDER=/data/uploads

# -----------------------------------------------------------------------------
# E-MAIL — SMTP (obrigatório para recuperação de senha)
# -----------------------------------------------------------------------------
#
# Gmail com App Password (recomendado):
#   1. myaccount.google.com → Segurança → Verificação em 2 etapas (ativar)
#   2. Pesquise "Senhas de app" → Gerar → Selecione "Outro" → nomeie "ColaboraEdu"
#   3. Copie os 16 caracteres gerados e cole em SMTP_PASSWORD (sem espaços)
#   4. Use o endereço Gmail em SMTP_USER e SMTP_FROM
#
# Outros provedores:
#   Outlook/Office365: smtp.office365.com  porta 587
#   SendGrid:          smtp.sendgrid.net   porta 587  (SMTP_USER=apikey)
#   Amazon SES:        email-smtp.<região>.amazonaws.com  porta 587
#
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@minhaescola.com.br
# IMPORTANTE: Se usar Gmail App Password, remova os espaços da senha gerada
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_FROM=noreply@minhaescola.com.br

# -----------------------------------------------------------------------------
# WHATSAPP — Evolution API (opcional)
# Deixe os campos em branco para desabilitar o envio via WhatsApp.
# -----------------------------------------------------------------------------
#
# Como configurar:
#   1. Instale a Evolution API (https://doc.evolution-api.com)
#   2. Crie uma instância e conecte ao WhatsApp via QR Code
#   3. Copie a URL base, o API Token e o nome da instância abaixo
#
WHATSAPP_API_URL=https://evolution.minhaescola.com.br
WHATSAPP_API_TOKEN=SEU_TOKEN_EVOLUTION_AQUI
# Nome exato da instância criada no painel da Evolution API
WHATSAPP_INSTANCE=colaboraedu

# -----------------------------------------------------------------------------
# MODO COMERCIAL
# -----------------------------------------------------------------------------
# saas       → multi-escola, cada escola é um tenant (padrão)
# dedicated  → instalação dedicada para uma única escola
COMMERCIAL_MODE=saas

# -----------------------------------------------------------------------------
# MONITORAMENTO DE ERROS — Sentry (opcional)
# -----------------------------------------------------------------------------
# Deixe em branco para desabilitar. Quando preenchido, exceções não tratadas
# e erros de SQL/RQ são enviados automaticamente para o Sentry.
#
# Como obter:
#   1. sentry.io → New Project → Python → Flask
#   2. Copie o DSN gerado (formato: https://xxx@oYYY.ingest.sentry.io/ZZZ)
#
SENTRY_DSN=

# =============================================================================
# BACKUP EXTERNO (Opcional — fortemente recomendado em produção)
# =============================================================================
# Backup diário do PostgreSQL é salvo localmente por 30 dias.
# BACKUP_ENCRYPTION_KEY é obrigatório em produção: o serviço pgbackup recusa
# gerar dumps sem criptografia.
# Gere com: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=TROQUE_POR_CHAVE_BACKUP_32_CHARS_MINIMO

# Para enviar também para object storage S3-compatible (Backblaze B2, AWS S3,
# MinIO, etc.), preencha as variáveis abaixo.
#
# Formato de S3_BACKUP_BUCKET: nome-do-bucket/pasta (ex: colaboraedu-backups/prod)
# S3_ENDPOINT: deixe em branco para AWS. Para Backblaze B2:
#   S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#
S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT=

# =============================================================================
# FATURAMENTO — Stripe (Sprint 10 / F5)
# =============================================================================
# Como configurar:
#   1. stripe.com → Dashboard → Desenvolvedores → API Keys
#   2. Copie a chave secreta (sk_live_...) em STRIPE_SECRET_KEY
#   3. Crie um produto/preço mensal e copie o Price ID (price_...) em STRIPE_PRICE_ID
#   4. Em Webhooks → Adicionar endpoint: https://api.seudominio.com/api/v1/billing/stripe/webhook
#      Eventos a escutar: checkout.session.completed, customer.subscription.*,
#      invoice.payment_failed
#   5. Copie o Signing Secret do webhook em STRIPE_WEBHOOK_SECRET
#
STRIPE_SECRET_KEY=sk_live_TROQUE_PELA_CHAVE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_TROQUE_PELO_SIGNING_SECRET
STRIPE_PRICE_ID=price_TROQUE_PELO_PRICE_ID_DO_PLANO
